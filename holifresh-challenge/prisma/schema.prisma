generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Room model
model Room {
  id                 String   @id // roomCode provided by admin
  name               String
  status             String   @default("DRAFT") // DRAFT, OPEN, LIVE, CLOSED
  joinCode           String
  objectiveTotal     Int      @default(0)
  rdvValueCents      Int      @default(0)
  cagnotteValueCents Int      @default(0) // Cagnotte per RDV (should be <= rdvValueCents)
  createdAt          DateTime @default(now())
  openedAt           DateTime?
  launchedAt         DateTime? // When event goes LIVE
  closedAt           DateTime?
  signaturesGoal     Int      @default(0)

  participants      Participant[]
  claims            Claim[]
  boosts            Boost[]
}

// Participant model
model Participant {
  id              String   @id @default(uuid())
  roomId          String
  displayName     String
  displayNameKey  String   // Normalized version for collision checks
  tokenHash       String   @unique // Secret token hash stored on client
  lastClaimAt     DateTime?
  createdAt       DateTime @default(now())

  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  claims          Claim[]

  @@unique([roomId, displayNameKey])
}

// Claim model (event log)
model Claim {
  id               String   @id @default(uuid())
  roomId           String
  participantId    String
  type             String   @default("RDV") // "RDV" for standard claim, "BONUS" for direct cagnotte addition
  valueCents       Int?     // Specific monetary value for the bonus (only used when type="BONUS")
  createdAt        DateTime @default(now())
  clientRequestId  String   @unique // Idempotency check
  status           String   @default("VALID") // VALID, CANCELLED
  cancelledAt      DateTime?
  cancelledBy      String?
  cancelReason     String?

  room             Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  participant      Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  claimBoosts      ClaimBoost[]
}

// Boost model
model Boost {
  id              String    @id @default(uuid())
  roomId          String
  label           String    // ex: "🌅 Last Call", "🕵️ Stand Voisin"
  description     String?   // Optional description for the boost
  type            String    // "MULTIPLIER", "FLAT_BONUS", or "PALIER"
  multiplier      Float?    // ex: 2.0 for x2 (when type = MULTIPLIER)
  bonusCents      Int?      // ex: 2500 for +25€ (when type = FLAT_BONUS or PALIER)
  palierScope     String?   // "INDIVIDUAL" or "TEAM" (when type = PALIER)
  palierTarget    Int?      // The number of RDV to reach (e.g. 5, 10, 50)
  trigger         String?   // "MANUAL" | "ON_EVENT_START" (null = manual)
  durationMin     Int?      // Duration in minutes (alternative to endAt)
  isActive        Boolean   @default(false)
  activatedAt     DateTime? // When the boost was actually activated
  startAt         DateTime? // Scheduled auto-start (nullable = manual only)
  endAt           DateTime? // Scheduled auto-end (nullable = manual deactivation)
  createdAt       DateTime  @default(now())

  room            Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  claimBoosts     ClaimBoost[]
}

// Junction table: which boosts applied to which claims
model ClaimBoost {
  id          String   @id @default(uuid())
  claimId     String
  boostId     String
  createdAt   DateTime @default(now())

  claim       Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  boost       Boost    @relation(fields: [boostId], references: [id], onDelete: Cascade)

  @@unique([claimId, boostId])
}
